{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],

    "jsx": "react-jsx",

    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "verbatimModuleSyntax": true,
    "declaration": true,
    "isolatedDeclarations": true,

    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,

    "noEmit": true
  }
}
